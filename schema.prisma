generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  externalUserId String    @unique @db.Uuid
  email          String    @unique
  role           Role      
  avatarUrl      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt

  studentProfile StudentProfile?
  companyProfile CompanyProfile?

  @@map("users")
}

model StudentProfile {
  userId             Int      @id @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime? @updatedAt

  // Informations personnelles
  firstName          String
  lastName           String
  biography          String?
  dateOfBirth        DateTime?
  city               String?
  country            String? @default("France")

  // Situation scolaire actuelle
  schoolName         String?
  degreeName         String?
  fieldOfStudy       FieldOfStudy?
  startYear          Int?
  graduationYear     Int?
  currentLevel       StudyLevel?
  targetLevel        StudyLevel?

  // Compétences
  skills             String[]
  languages          String[]

  // Recherche d'emploi
  openTo             ContractType[]
  preferredLocations String[]
  availableOn        DateTime?

  // Préférences
  isVisible          Boolean       @default(false)
  showLastName       Boolean       @default(false)

  // CV et réseaux sociaux
  cvUrl              String?
  portfolioUrl String? 
  linkedinUrl  String? 
  githubUrl    String?

  // Contact
  contactPhone       String?
  contactEmail       String?

  // Relations étrangères
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications OfferApplication[]
  savedOffers StudentSavedOffer[]

  @@map("student_profiles")
}

model StudentSavedOffer {
  studentId Int
  offerId Int
  createdAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@id([studentId, offerId])
  @@index([offerId])
}

model CompanyProfile {
    // id                 Int           @id @default(autoincrement())

  userId             Int           @id @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime? @updatedAt

  // Informations légales
  legalName          String
  siret             String?
  description       String?
  slogan            String?
  industry           Industry?
  size              CompanySize?
  employeeCount   Int?

  // Adresse
  address     String?
  city        String?
  postalCode  String?
  country String? @default("France")

  // Histoire
  foundedIn         DateTime?
  values   String[]
  benefits String[]

  // Images et couleurs
  logoUrl String?
  coverUrl String?
  primaryColor  String? @default("#EE7527")

  // Réseaux sociaux
  websiteUrl String? 
  linkedinUrl  String? 

  // Contact
  contactPhone       String?
  contactEmail       String?

  // Relations étrangères
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers             Offer[]

  @@map("company_profiles")
}

enum OfferStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model Offer {
  id           Int          @id @default(autoincrement())
  companyId   Int           
  status       OfferStatus  @default(DRAFT)
  createdAt DateTime       @default(now())
  updatedAt DateTime?       @updatedAt
  publishedAt DateTime?

  // Détails
  title        String
  description  String
  shortDescription String? 
  startDate DateTime?
  applicationDeadline DateTime?
  fieldOfStudy FieldOfStudy?

  // Légal
  contractType ContractType[]
  duration_min Int?
  duration_min_unit DurationUnit?
  duration_max Int?
  duration_max_unit DurationUnit?
  salaryMin   Int?
  salaryMax   Int? 
  appliesMinimumWage Boolean @default(false)

  // Location and remote work
  city String?
  country String? @default("France")
  remoteType RemoteType?

  // Visibilité
  isFeatured Boolean @default(false)
  viewCount Int @default(0)

  // Relations étrangères
  company   CompanyProfile @relation(fields: [companyId], references: [userId], onDelete: Cascade)
  applications OfferApplication[]
  savedBy       StudentSavedOffer[]

  @@map("offers")
}

model OfferApplication {
  id          Int                    @id @default(autoincrement())
  description String                 @db.Text
  cvUrl       String
  status      OfferApplicationStatus @default(SUBMITTED)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime?              @updatedAt

  // Clés étrangères et relations
  studentId Int
  student   StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  offerId Int
  offer   Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("offer_applications")
}

enum OfferApplicationStatus {
  SUBMITTED
  REJECTED
  ACCEPTED
  CANCELLED
}

enum Role {
  ADMIN
  STUDENT
  COMPANY
}

enum Industry {
  AEROSPACE
  AGRICULTURE
  AUTOMOTIVE
  BANKING_INSURANCE
  CONSTRUCTION
  EDUCATION
  ENERGY
  HEALTHCARE
  HOSPITALITY
  IT_SERVICES
  LUXURY
  MANUFACTURING
  MEDIA_ENTERTAINMENT
  RETAIL
  PUBLIC_SECTOR
  TRANSPORT_LOGISTICS
}

enum FieldOfStudy {
  ADMINISTRATION
  ARTS_DESIGN
  BUSINESS_MANAGEMENT
  COMMUNICATION
  COMPUTER_SCIENCE
  DATA_ANALYTICS
  ENGINEERING
  FINANCE_ACCOUNTING
  HUMAN_RESOURCES
  LAW
  MARKETING
  SALES
}

enum StudyLevel {
  BAC_PLUS_2 // BTS, DUT, DEUST
  BAC_PLUS_3 // Licence, Bachelor, BUT
  BAC_PLUS_4 // Master 1
  BAC_PLUS_5 // Master 2, Diplôme d'Ingénieur, École de Commerce
  BAC_PLUS_6 // Master Spécialisé
  DOCTORATE // Doctorat
}

enum ContractType {
  INTERNSHIP     // Stage
  APPRENTICESHIP  // Alternance
}

enum CompanySize {
  TPE   // 0-10
  PME   // 10-250
  ETI   // 250-5000
  GE    // +5000
}

enum DurationUnit {
  DAYS 
  MONTHS
  YEARS
}

enum RemoteType {
  ON_SITE
  HYBRID
  FULL_REMOTE
}