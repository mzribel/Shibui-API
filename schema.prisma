generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  externalUserId String    @unique @db.Uuid
  email          String    @unique
  role           Role      
  avatarUrl      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt

  studentProfile StudentProfile?
  companyProfile CompanyProfile?

  @@map("users")
}

model StudentProfile {
  // id                 Int           @id @default(autoincrement())
  userId             Int           @id @unique

  // Informations personnelles
  firstName          String
  lastName           String
  biography          String?
  dateOfBirth        DateTime?
  city               String?
  country            String? @default("France")

  // Contact
  contactPhone       String?
  contactEmail       String?

  // Situation scolaire actuelle
  schoolName         String?
  degreeName         String?
  fieldOfStudy       FieldOfStudy?
  startYear          Int?
  graduationYear     Int?
  currentLevel       StudyLevel?
  targetLevel        StudyLevel?

  // Compétences
  skills             String[]
  languages          String[]

  // CV et réseaux sociaux
  cvUrl              String?
  portfolioUrl String? @map("portfolio_url")
  linkedinUrl  String? @map("linkedin_url")
  githubUrl    String? @map("github_url")

  // Recherche d'emploi
  openTo             ContractType[]
  preferredLocations String[]
  availableOn        DateTime?

  // Préférences
  isVisible          Boolean       @default(false)
  showLastName       Boolean       @default(false)

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications OfferApplication[]
  savedOffers StudentSavedOffer[]

  @@map("student_profiles")
}

model StudentSavedOffer {
  studentId Int
  offerId Int
  createdAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@id([studentId, offerId])
  @@index([offerId])
}


model CompanyProfile {
  userId             Int       @id @unique
  legalName          String
  industry           Industry?
  description        String?   @db.Text
  siret              String?
  isVerified         Boolean   @default(false)
  contactPhoneNumber String?
  contactEmail       String?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers             Offer[]

  @@map("company_profiles")
}

enum OfferStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model Offer {
  id           Int          @id @default(autoincrement())
  title        String
  description  String
  location     String
  salary       Int?
  status       OfferStatus  @default(DRAFT)
  fieldOfStudy FieldOfStudy

  // Relations
  companyId Int
  company   CompanyProfile @relation(fields: [companyId], references: [userId], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  applications OfferApplication[]
  savedBy       StudentSavedOffer[]
  @@map("offers")
}

model OfferApplication {
  id          Int                    @id @default(autoincrement())
  description String                 @db.Text
  cvUrl       String
  status      OfferApplicationStatus @default(SUBMITTED)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime?              @updatedAt

  // Clés étrangères et relations
  studentId Int
  student   StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  offerId Int
  offer   Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("offer_applications")
}

enum OfferApplicationStatus {
  SUBMITTED
  REJECTED
  ACCEPTED
  CANCELLED
}

enum Role {
  ADMIN
  STUDENT
  COMPANY
}

enum Industry {
  AEROSPACE
  AGRICULTURE
  AUTOMOTIVE
  BANKING_INSURANCE
  CONSTRUCTION
  EDUCATION
  ENERGY
  HEALTHCARE
  HOSPITALITY
  IT_SERVICES
  LUXURY
  MANUFACTURING
  MEDIA_ENTERTAINMENT
  RETAIL
  PUBLIC_SECTOR
  TRANSPORT_LOGISTICS
}

enum FieldOfStudy {
  ADMINISTRATION
  ARTS_DESIGN
  BUSINESS_MANAGEMENT
  COMMUNICATION
  COMPUTER_SCIENCE
  DATA_ANALYTICS
  ENGINEERING
  FINANCE_ACCOUNTING
  HUMAN_RESOURCES
  LAW
  MARKETING
  SALES
}

enum StudyLevel {
  BAC_PLUS_2 // BTS, DUT, DEUST
  BAC_PLUS_3 // Licence, Bachelor, BUT
  BAC_PLUS_4 // Master 1
  BAC_PLUS_5 // Master 2, Diplôme d'Ingénieur, École de Commerce
  BAC_PLUS_6 // Master Spécialisé
  DOCTORATE // Doctorat
}

enum ContractType {
  INTERNSHIP     // Stage
  APPRENTICESHIP  // Alternance
}